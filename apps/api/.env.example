### API env (example)
# Copy to `.env` and fill with real values. Do NOT commit `.env`.

THE_ODDS_API_KEY=
DATABASE_URL="file:./dev.db"
API_FOOTBALL_KEY=
FOOTBALL_DATA_TOKEN=
# Comma-separated admin emails for scan/results/notify endpoints
ADMIN_EMAILS=
# Comma-separated frontend URLs for CORS (production)
ALLOWED_ORIGINS=http://localhost:3000

# Turso (production persistent DB) — leave empty for local SQLite
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Shared secret for free external cron (cron-job.org). Long random string.
CRON_SECRET=
